# Database Configuration
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=typo3
MYSQL_USER=typo3
MYSQL_PASSWORD=typo3

# TYPO3 Configuration
TYPO3_VERSION=14.0
TYPO3_ADMIN_USER=admin
TYPO3_ADMIN_PASSWORD=admin123
TYPO3_ADMIN_EMAIL=admin@example.com
TYPO3_INSTALL_TOOL_PASSWORD=install123

# Note: The Agency Powerstack frontend URL is determined automatically.
#   Development (APPLICATION_CONTEXT=Development or localhost): http://localhost:3081
#   Production: https://app.agency-powerstack.com
# No manual configuration is required.

# Optional: Docker Host Override for Development
# Uncomment if backend runs in Docker and needs to reach TYPO3 on host
# TYPO3_HOST_OVERRIDE=host.docker.internal
