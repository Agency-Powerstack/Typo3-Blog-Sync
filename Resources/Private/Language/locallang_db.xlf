			</trans-unit>
			<trans-unit id="tx_blogsync_log.message">
				<source>Message</source>
			</trans-unit>
			<trans-unit id="tx_blogsync_log.details">
				<source>Details (JSON)</source>
			</trans-unit>

			<trans-unit id="tx_blog_post.external_id">
				<source>External ID (Blog Sync)</source>
			</trans-unit>
		</body>
