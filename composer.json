{
  "name": "agencypowerstack/typo3-blog-sync",
  "type": "typo3-cms-extension",
  "description": "Synchronize blogs from Agency Powerstack to TYPO3 Blog extension via REST API",
  "homepage": "https://agency-powerstack.com",
  "license": "proprietary",
  "keywords": ["typo3", "blog", "sync", "agency-powerstack", "cms", "webhook"],
  "authors": [
    {
      "name": "Agency Powerstack",
      "email": "info@agency-powerstack.com",
      "homepage": "https://agency-powerstack.com"
    }
  ],
  "support": {
    "email": "info@agency-powerstack.com",
    "url": "https://agency-powerstack.com"
  },
  "require": {
    "php": "^8.2",
    "typo3/cms-core": "^13.4 || ^14.0",
    "t3g/blog": "*"
  },
  "autoload": {
    "psr-4": {
      "AgencyPowerstack\\BlogSync\\": "Classes/"
    }
  },
  "extra": {
    "typo3/cms": {
      "extension-key": "blog_sync"
    }
  }
}
